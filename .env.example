# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# IP address or hostname of the remote VM to SSH into.
# Every run_command, run_script, scp_upload, and scp_download targets this host.
HOST_IP=192.168.1.100

# SSH user to authenticate as on the remote VM.
# Typically: ubuntu (Ubuntu AMIs), ec2-user (Amazon Linux), root, etc.
USERNAME=ubuntu

# ---------------------------------------------------------------------------
# Auth — exactly any of the one method is used (SECRET_NAME, S3_BUCKET+S3_KEY, SSH_KEY, PASSWORD)
# ---------------------------------------------------------------------------

# AWS Secrets Manager
# Name of a Secrets Manager secret containing SSH credentials.
# The secret value must be JSON with an "SSH_KEY" (PEM string) or "PASSWORD" field.
# Requires IAM permission: secretsmanager:GetSecretValue
SECRET_NAME=ssh-mcp-key
SECRET_REGION=us-east-1       # Region of the secret (default: us-east-1)

# [Priority 2] S3 — PEM key file stored as an S3 object (both vars required together)
# Requires IAM permission: s3:GetObject on the specified object.
S3_BUCKET=your-bucket
S3_KEY=path/to/key.pem
AWS_REGION=us-east-1          # Region for the S3 client (default: us-east-1)

# [Priority 3] Inline PEM private key string.
# Use \n (literal backslash-n) for newlines — the server normalises them at startup.
# Convenient locally; avoid in production as the key appears in env var logs.
SSH_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# [Priority 4] Plain SSH password. Used only if no key method is set.
PASSWORD=your_password

# ---------------------------------------------------------------------------
# Optional
# ---------------------------------------------------------------------------

# Port this MCP server listens on for HTTP traffic (/mcp and /health).
# When running in Docker, match the -p flag: e.g. -p 9000:9000 with PORT=9000.
# Default: 8000
PORT=8000

# SSH port on the remote VM. Change if the target runs SSH on a non-standard port.
# Default: 22
SSH_PORT=22

# Directory inside the container used as the local staging area for file transfers.
# scp_upload reads files from here before pushing to the remote VM.
# scp_download saves files here after pulling from the remote VM.
# workspace_list, workspace_read, workspace_write also operate on this directory.
# In Docker: mount a host directory here with -v /host/dir:/transfers.
# In AgentCore: use S3 Files access point or EFS to store files presistently.
# Default: /transfers
FILE_PATH=/transfers

# Seconds of inactivity before the background reaper closes the SSH connection.
# The connection is re-established automatically on the next tool call.
# Lower = fewer idle connections on the remote VM.
# Higher = less reconnection latency for bursty workloads.
# Default: 60
IDLE_TIMEOUT=60